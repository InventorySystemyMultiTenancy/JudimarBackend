# Em produção (Render), DATABASE_URL é injetado automaticamente via fromDatabase
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pizzaria_china?schema=public"

# Gere um valor seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-um-segredo-forte"
JWT_EXPIRES_IN="8h"
PORT=3000

# URL do frontend (usado no CORS)
CORS_ORIGIN="http://localhost:5173"

SEED_ADMIN_EMAIL="admin@pizzariachina.com"
SEED_ADMIN_PASSWORD="Admin123!"
